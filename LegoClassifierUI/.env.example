# DLL paths for Windows (required for OpenCV bindings)
OPENCV_DLL_PATH=C:\path\to\opencv\bin
MSYS64_DLL_PATH=C:\msys64\ucrt64\bin
# Path to the directory containing lego_classifier.pyd
BINDINGS_PATH=C:\path\to\LegoClassifierUtils\cmake-build-release-windows\LegoContours\bindings

# USB connection
USB_PORT=
USB_BAUD_RATE=115200
USB_TIMEOUT=1

# Database (leave empty to use default: lego_features.db in project root)
DATABASE_PATH=
